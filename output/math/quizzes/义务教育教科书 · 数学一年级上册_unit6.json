  "knowledge_summary": [
    {
      "point": "计数单位“十”与数位认识",
      "core_concept": "理解个位和十位的含义。10个一合起来是一个“十”，在计数器上，十位上的一个珠子表示1个十，个位上的一个颗珠子表示1个一。右边起第一位是个位，第二位是十位。",
      "key_formula": "$10个一 = 1个十$",
      "common_mistakes": [
        "分不清数位顺序，以为左边起第一位是个位。",
        "理解偏差，认为20个一就是1个十。"
      ],
      "tips": "可以通过捆小棒的方法来记忆，10根捆成一捆，一捆就代表一个十。"
    },
    {
      "point": "11~20各数的写法与组成",
      "core_concept": "11~20各数都是由1个十和几个一组成的（20是由2个十组成的）。写数时，有几个十就在十位写几，有几个一就在个位写几。如果个位上一个单位也没有，要写0占位。",
      "key_formula": "$1个十 + n个一 = 1n$",
      "common_mistakes": [
        "写“二十”时写成“2”，漏掉个位的0。",
        "读数和写数混淆，将“15”读成“一五”。"
      ],
      "tips": "写数时一定要注意数位，先写十位再写个位，没数就用0住位置。"
    },
