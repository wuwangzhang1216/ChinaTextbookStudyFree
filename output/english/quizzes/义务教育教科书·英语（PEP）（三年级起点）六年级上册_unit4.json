  "knowledge_summary": [
    {
      "point": "Expressing Hobbies (like doing)",
      "core_concept": "用 'like' 后接动词的 -ing 形式来表达人的兴趣爱好。",
      "key_formula": "Subject + like/likes + v-ing (e.g., I like singing; He likes singing.)",
      "common_mistakes": [
        "like 后面直接用原形 (I like sing)",
        "忘了根据主语变 likes"
      ],
      "tips": "记住 '两个动词不能连用'，要把第二个动词穿上 -ing 的外衣（动名词）。"
    },
    {
      "point": "Third Person Singular (Simple Present)",
      "core_concept": "当主语为 He, She, It 或单数名词时，谓语动词需做相应变化。",
      "key_formula": "1. 一般加 -s; 2. ch, sh, s, x, o 结尾加 -es; 3. 辅音+y 变 i 加 -es.",
      "common_mistakes": [
        "He live... (漏掉s)",
        "She teachs... (拼写错误, 应该是 teaches)"
      ],
      "tips": "想象主语是'三单'大王，动词作为随从必须带一个s标志。"
    },
    {
      "point": "Interrogative Sentences (Does/What)",
      "core_concept": "使用 Does 引导一般疑问句，What 引导特殊疑问句谈论他人信息。",
      "key_formula": "What are his/her hobbies? / Does he/she like...? / Where does he/she live?",
      "common_mistakes": [
        "Does he likes... (Does 出现后动词必须还原)",
        "What is his hobbies? (hobbies 是复数需用 are)"
      ],
      "tips": "助动词 Does 就像照妖镜，它一出来，动词的三单形式就要变回原形。"
    }
  ]
}