  "knowledge_summary": [
    {
      "point": "不规则动词过去式变化",
      "core_concept": "部分高频动词在一般过去时中不遵循加ed的规则，需逐一记忆。",
      "key_formula": "go->went, ride->rode, buy->bought, eat->ate, see->saw, take->took",
      "common_mistakes": [
        "将go过去式写成goed",
        "在did引导的问句中误用动词过去式"
      ],
      "tips": "通过编儿歌或制作闪卡记忆这些特殊形式。"
    },
    {
      "point": "Where/How/Who 引导的过去时询问",
      "core_concept": "使用特殊疑问句询问过去旅程的地点、方式和同伴。",
      "key_formula": "疑问词 + did + 主语 + 动词原形 + 其它？",
      "common_mistakes": [
        "疑问词混淆，如问地点用了How",
        "忘记将do改为did"
      ],
      "tips": "先确定你想知道什么（人、地、物），再选择对应的疑问词。"
    },
    {
      "point": "一般过去时的肯定与否定",
      "core_concept": "描述过去发生的动作，肯定句变动词，否定句用didn't加原形。",
      "key_formula": "肯定：主语+动词过; 否定：主语+didn't+动词原形",
      "common_mistakes": [
        "didn't 后面跟了过去式形式",
        "忽略时间状语（yesterday, last week）的影响"
      ],
      "tips": "看到did/didn't，后面的动词必须‘打回原形’。"
    }
  ]
}