  "knowledge_summary": [
    {
      "point": "打招呼与问候",
      "core_concept": "在非正式场合使用Hello或Hi引起对方注意或问好。",
      "key_formula": "Hello / Hi! 用于打招呼；Goodbye / Bye! 用于告别。",
      "common_mistakes": [
        "将Hello用于道别",
        "回答Hello时错用Goodbye"
      ],
      "tips": "英语中主动打招呼是友好的表现，建议多说Hi以拉近人际距离。"
    },
    {
      "point": "自我介绍与询问姓名",
      "core_concept": "介绍自己的名字以及询问别人是谁。",
      "key_formula": "I'm... / My name's... 介绍自己；What's your name? 询问姓名。",
      "common_mistakes": [
        "My name's 后接 I'm",
        "询问他人姓名时丢掉物主代词your"
      ],
      "tips": "介绍自己时，手指向自己可以帮助初学者更好地理解I的含义。"
    },
    {
      "point": "冠词 a 和 an 的区别",
      "core_concept": "根据名词首字母的发音决定不定冠词的形式。",
      "key_formula": "元音音素(a, e, i, o, u开头单词)前用an；辅音音素前用a。",
      "common_mistakes": [
        "a eraser",
        "an bag"
      ],
      "tips": "记口诀：元音前an，辅音前a，看图说话别弄差。"
    }
  ]
}