  "knowledge_summary": [
    {
      "point": "钟面时刻的认读",
      "core_concept": "钟面上有时针和分针，12个大格，60个小格。读数时先看时针，过几就是几时；再看分针，走过几个小格就是几分。分针指着几，就用五个五地数的方法数出分钟数。",
      "key_formula": "分钟数 = 分针指向的数字 \times 5",
      "common_mistakes": [
        "将时针看错，如 4:55 误认为 5:55，因为时针很靠近5。",
        "分针指向“1”时读成1分，实际应该是5分。"
      ],
