  "knowledge_summary": [
    {
      "point": "核心食物词汇",
      "core_concept": "掌握beef, soup, vegetables, noodles等词的音形义。",
      "key_formula": "名词单复数：vegetables(常用复数), soup/beef/rice(不可数), noodles(复数)。",
      "common_mistakes": [
        "把soup错写成soop",
        "vegetable拼写错误",
        "混淆不可数名词与可数名词复数"
      ],
      "tips": "可以通过‘看图连线’或‘模拟餐厅点餐’来强化记忆。"
    },
    {
      "point": "用餐器具词汇",
      "core_concept": "识别并拼写bowl, chopsticks, spoon, fork, knife。",
      "key_formula": "chopsticks通常以双数复数形式出现；knife复数形式是knives(本单元暂不强制)。",
      "common_mistakes": [
        "chopsticks漏掉s",
        "knife与fork意思记反"
      ],
      "tips": "结合实际餐桌摆放进行方位和名称练习。"
    },
    {
      "point": "Would you like...句型",
      "core_concept": "用于委婉征求他人意见或点餐。",
      "key_formula": "问：Would you like + 食物? 答：Yes, please. / No, thanks.",
      "common_mistakes": [
        "Would后面接了动词do",
        "拒绝时忘记加thanks导致不礼貌"
      ],
      "tips": "紧记'礼貌第一'，无论接受还是拒绝都要加please或thanks。"
    },
    {
      "point": "字母e的发音规律",
      "core_concept": "元音字母e在开音节(word-final e)中发长音/i:/。",
      "key_formula": "me, he, she, we -> 字母e发音为/i:/。",
      "common_mistakes": [
        "将me读成短音/e/",
        "无法区分bed中的e与me中的e"
      ],
      "tips": "记住口诀：'我'me,'他'he,'她'she,'我们'we，结尾字母e，火车鸣笛/i:/ /i:/ /i:/。"
    }
  ]
}