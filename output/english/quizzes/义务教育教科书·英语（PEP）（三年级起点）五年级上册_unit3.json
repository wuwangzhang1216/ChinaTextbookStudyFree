  "knowledge_summary": [
    {
      "point": "饮食相关名词",
      "core_concept": "掌握 sandwich, salad, hamburger, ice cream, tea 等高频饮食词汇。",
      "key_formula": "可数名词注意复数（sandwiches），不可数名词(water, milk, soup)不加s。",
      "common_mistakes": [
        "把 hamburger 拼成 hanburger",
        "忘记 sandwich 复数加 es"
      ],
      "tips": "可以将食物按 'Healthy (健康)' 和 'Unhealthy (不健康)' 分类记忆。"
    },
    {
      "point": "味道形容词",
      "core_concept": "使用 fresh, healthy, delicious, hot, sweet 描述食物。",
      "key_formula": "It is + 形容词. / They are + 形容词.",
      "common_mistakes": [
        "误认为 hot 只有 '热' 的意思，忽略了其 '辣' 的含义"
      ],
      "tips": "通过对比学习，如 sweet 对比 sour。"
    },
    {
      "point": "点餐与偏好句型",
      "core_concept": "What would you like to eat/drink? 与 What's your favourite food?",
      "key_formula": "I'd like... = I would like...",
      "common_mistakes": [
        "回答 drink 问句时回答了食物",
        "like 后面漏掉 to (would like to eat)"
      ],
      "tips": "记住 'Would like' 语气比 'Want' 更委婉有礼貌。"
    },
    {
      "point": "语音规律：ow",
      "core_concept": "区分 ow 的两种主要发音：/aʊ/ 和 /əʊ/。",
      "key_formula": "双元音：/aʊ/ (cow, flower, now); /əʊ/ (slow, snow, yellow)。",
      "common_mistakes": [
        "将 snow 读成 /snaʊ/",
        "混合两组单词的归类"
      ],
      "tips": "口诀：黄色的(yellow)雪(snow)慢慢的(slow)下，牛儿(cow)现在(now)看花(flower)。"
    }
  ]
