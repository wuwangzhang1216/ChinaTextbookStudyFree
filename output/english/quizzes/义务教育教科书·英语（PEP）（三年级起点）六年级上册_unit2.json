  "knowledge_summary": [
    {
      "point": "常见交通工具表达",
      "core_concept": "熟练掌握 by+交通工具 的结构（注意交通工具前不加词）",
      "key_formula": "by bus / by plane / by subway / by ship / by bike / on foot (注意foot用on)",
      "common_mistakes": [
        "错误使用 by the bus",
        "将 on foot 误写为 by foot"
      ],
      "tips": "记忆口诀：方式介词by领头，工具单数跟在后；若是步行走着去，脚下一定要用on。"
    },
    {
      "point": "频度副词的用法",
      "core_concept": "描述动作发生的频率",
      "key_formula": "Always (100%) > Usually (80%) > Often (60%) > Sometimes (20%)",
      "common_mistakes": [
        "频度副词在句子中的位置放置错误",
        "拼写错误尤其是usually"
      ],
      "tips": "频度副词通常放在实义动词之前，be动词之后。"
    },
    {
      "point": "交通信号与规则",
      "core_concept": "红绿灯含义及应遵守的安全规则",
      "key_formula": "Red: Stop and wait; Yellow: Slow down and stop; Green: Go",
      "common_mistakes": [
        "混合了yellow和red的动作指令",
        "忽视祈使句否定形式以Don't开头"
      ],
      "tips": "记住 'Red, stop; Yellow, wait; Green, go' 的三字经。"
    }
  ]
