  "knowledge_summary": [
    {
      "point": "动物类单词及其特征",
      "core_concept": "能够识别常见的动物名称，并能在实际情景中运用。",
      "key_formula": "panda, tiger, elephant, monkey, bird, duck, pig",
      "common_mistakes": [
        "混淆 bird 和 bear 的拼写与读音",
        "忘记 elephant 前面要用 an 而不是 a"
      ],
      "tips": "可以通过模仿动物的叫声或动作（如 Act like a...）来辅助记忆。"
    },
    {
      "point": "指示代词 this 和 that 的区别",
      "core_concept": "区分近处和远处物体的询问方式。",
      "key_formula": "What's this? (近处) / What's that? (远处) -> 回答统一用 It's a/an...",
      "common_mistakes": [
        "在回答时使用 This is... 而不是 It's...",
        "that's 的发音不清晰"
      ],
      "tips": "手指触碰得到的用this，指着远方看不清的用that。"
    },
    {
      "point": "字母 Jj 至 Nn 及其首字母发音",
      "core_concept": "掌握 J-N 的字母顺序、书写及在单词中的发音规律（Phonics）。",
      "key_formula": "j-jump, k-kite, l-leg, m-mum, n-nose",
      "common_mistakes": [
        "字母 L 的小写 l 容易和数字 1 或大写 I 混淆",
        "字母 M 和 N 的读音区分不明显"
      ],
      "tips": "多观察字母在四线三格中的占格，M, N 又是两个鼻音，注意发音部位。"
    }
  ]
