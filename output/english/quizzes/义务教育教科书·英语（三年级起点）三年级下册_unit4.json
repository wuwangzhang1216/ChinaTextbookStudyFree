  "knowledge_summary": [
    {
      "point": "方位介词的三剑客",
      "core_concept": "准确区分 in, on, under 表达的相对位置关系。",
      "key_formula": "in (在里面), on (在上面-接触表面), under (在下面)。",
      "common_mistakes": [
        "混淆 on 和 under",
        "在介词后面漏掉定冠词 the，如说成 on desk"
      ],
      "tips": "可以通过手势记忆：握拳在手心是in，手掌盖拳头是on，手掌在拳头底是under。"
    },
    {
      "point": "询问位置的万能句型",
      "core_concept": "使用 Where 引导的特殊疑问句寻找物品。",
      "key_formula": "Where is + (my/the) + 物品名称?",
      "common_mistakes": [
        "Where is 后面直接加名词忘了加 my 或 the",
        "回答时主语 it 和 is 缩写写错"
      ],
      "tips": "哪里(Where)是在(is)我的(my)车(car)？记住顺序：疑问词+be动词+名词。"
    },
    {
      "point": "字母 o 的短元音发音",
      "core_concept": "字母 o 在闭音节（辅+元+辅结构）中的发音规律。",
      "key_formula": "o -> /ɒ/ (张大嘴巴发'凹'的短音)",
      "common_mistakes": [
        "将 dog 读成长音 /oʊ/",
        "无法区分 body 和 go 中的 o 发音"
      ],
      "tips": "口诀：小狗 dog，坐盒子 box，全身 body，爱桔子 orange。"
    }
  ]
