  "knowledge_summary": [
    {
      "point": "农场词汇(复数变化)",
      "core_concept": "名词变复数一般加s，但部分o结尾及特殊词有别。",
      "key_formula": "potato/tomato+es; sheep单复同形",
      "common_mistakes": [
        "把potatoes写成potatos",
        "给sheep加s写成sheeps"
      ],
      "tips": "记口诀：土豆西红柿，变多加-es；绵羊不合群，单数复数一个形。"
    },
    {
      "point": "these与those指代",
      "core_concept": "指示代词的远近与单复数对应。",
      "key_formula": "these(近指复数); those(远指复数)",
      "common_mistakes": [
        "用this/that接are",
        "混淆these（近）和those（远）"
      ],
      "tips": "这些these在近处，那些those在远处。"
    },
    {
      "point": "How many 提问",
      "core_concept": "对可数名词数量的提问。",
      "key_formula": "How many + 名词复数 + do you have/are there?",
      "common_mistakes": [
        "How many后接了单数名词"
      ],
      "tips": "How many 后面必须跟'好多个'（复数形式）。"
    },
    {
      "point": "ar/al 发音",
      "core_concept": "字母组合在单词中的固定发音。",
      "key_formula": "ar /ɑː/, al /ɔː/",
      "common_mistakes": [
        "混淆ball与bar的发音"
      ],
      "tips": "ar就像张大嘴巴说'啊'，al就像公鸡打鸣'喔-'"
    }
  ]
