  "knowledge_summary": [
    {
      "point": "20以内数与运算的综合",
      "core_concept": "学生需熟练掌握20以内数的顺序、大小及组成。理解“10个一是一个十”。加减法方面重点复习“凑十法”和“破十法”，以此提高口算速度，并建立加减法互逆的关系。对于进位加法（如9+4），重点在于拆分较小的数，凑齐10。",
      "key_formula": "加数 + 加数 = 和；被减数 - 减数 = 差",
      "common_mistakes": [
        "计数单位混淆：如将“1个十和5个一”误写为“51”",
        "进位漏加：在计算 8+5 时，算出 12（忘记再加1）"
      ],
      "tips": "背熟20以内加法表，利用手指对照辅助理解数位关系。"
    },
