  "knowledge_summary": [
    {
      "point": "收集数据的方法",
      "core_concept": "在进行数据统计前，首先要通过调查获取原始信息。常用的调查方法有举手、无记名投票、分类排队等。在调查时，一定要明确调查的问题，并确保调查范围内的人都能参与且每人只能表达一个意愿，这样收集到的数据才真实有效。",
      "key_formula": "调查总人数 = 选择各选项的人数之和",
      "common_mistakes": [
        "统计时重复计数，导致总数超过实际人数",
        "漏掉部分调查对象，导致数据不完整"
      ],
      "tips": "调查前先设计好表格，调查时喊一个名字记一个，能有效防止漏记。"
    },
    {
      "point": "记录数据的方法（“正”字记录法）",
      "core_concept": "在收集数据时，由于数据是一个个出现的，我们需要用符号先记录下来。写“正”字法是最高效的方法，因为“正”字刚好5笔，每5项凑成一个字，最后通过数“正”字的个数乘5再加上剩下的笔画，就能快速算出总数。",
      "key_formula": "总数 = 完整的“正”字个数 \\times 5 + 剩余笔画数",
      "common_mistakes": [
        "数“正”字笔画时，把一个“正”字当成了4或6",
        "记录过程中，由于分心导致少画了笔画"
      ],
      "tips": "写“正”字要横平竖直，笔画清晰，每写完一个“正”字可以小小地圈一下防止数错。"
    },
    {
      "point": "统计表的制作与分析",
      "core_concept": "将记录的符号（如“正”字）转化为阿拉伯数字，并填入预先设计的表格中，这就是统计表。通过观察统计表，我们可以通过比较数字的大小，一眼看出谁“最多”、谁“最少”，还能进行加减法运算来求“总和”或“差量”，并根据现状做出简单的预测。",
      "key_formula": "比较规则：数值大的对应项为最多，数值小的对应项为最少。",
      "common_mistakes": [
        "看错行或列，导致数据填错位置",
        "计算合计人数时出现口算失误"
      ],
      "tips": "分析数据时，先用笔圈出最大和最小的数字，这样回答“最多”和“最少”就不会选错了。"
    }
  ]
