  "knowledge_summary": [
    {
      "point": "核心天气词汇",
      "core_concept": "描述天气状态的形容词，多数由名词词根+y构成。",
      "key_formula": "sun -> sunny; rain -> rainy; wind -> windy; cloud -> cloudy; snow -> snowy",
      "common_mistakes": [
        "把sunny拼写成suny（漏掉一个n）",
        "分不清warm(暖)和cool(凉)"
      ],
      "tips": "记忆秘诀：看到y结尾，联想天气美。有太阳是sunny，有雨水是rainy。"
    },
    {
      "point": "询问天气的固定句型",
      "core_concept": "询问特定地点或今日天气的句型表达。",
      "key_formula": "What's the weather like in [地点]? = How's the weather in [地点]?",
      "common_mistakes": [
        "说成 What's the weather is like? (重复含is)",
        "漏掉介词 in，如 What's the weather like Beijing?"
      ],
      "tips": "记住 'What' 和 'like' 是好搭档，'How' 出现就不带 'like'。"
    },
    {
      "point": "请求许可与建议",
      "core_concept": "基于天气情况判断能否进行某项活动。",
      "key_formula": "Can I + 动词原形? 回答: Yes, you can. / No, you can't.",
      "common_mistakes": [
        "can't后面接动词ing形式",
        "回答中使用 I 而不是 you，如 Yes, I can."
      ],
      "tips": "别人问'我可以吗？'你要答'你可以'。所以用'Yes, you can'。"
    }
  ]
}