  "knowledge_summary": [
    {
      "point": "面值的识别与单位进率",
      "core_concept": "认识各种面值的人民币（100元、50元、20元、10元、5元、1元、5角、1角等）。掌握三级单位元、角、分之间的十进制关系。",
      "key_formula": "$1元 = 10角, 1角 = 10分$",
      "common_mistakes": [
        "误以为1元等于100角",
        "记不清人民币的面值种类，如认为有3元或3角的钱"
      ],
      "tips": "可以通过换钱游戏来记忆：2个5角是1块，10个1角也是1块。"
    },
    {
      "point": "人民币单位的简单换算",
      "core_concept": "进行元、角、分之间的互化。大单位换小单位用加法（几个十），小单位换大单位看里面有几个十。",
      "key_formula": "$x元y角 = (10x + y)角$",
      "common_mistakes": [
