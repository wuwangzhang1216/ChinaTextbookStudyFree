  "knowledge_summary": [
    {
      "point": "计数单位与十进制概念",
      "core_concept": "万以内的计数单位包括个、十、百、千、万。每相邻两个计数单位之间的进率都是10（即满十进一）。10个一百是一千，10个一千是一万。",
      "key_formula": "$10 \\times 100 = 1000, 10 \\times 1000 = 10000$",
      "common_mistakes": [
        "误认为一万里面有10个一百",
        "在数数时遗漏某个计数单位"
      ],
      "tips": "可以借助拨珠子的方式感受‘满十进一’的过程。"
    },
    {
      "point": "万以内数的读写规则",
      "core_concept": "读写数都要从高位起。写数时哪一位上一个单位也没有，就写0占位；读数时中间有一个或两个0都只读一个‘零’，末尾的0都不读。",
      "key_formula": "从高位起，按位读/写，中间0读，末尾0不读。",
      "common_mistakes": [
